---
import HeroArt from './HeroArt.astro'
---
<section class="hero" style="display:grid; grid-template-columns:5fr 3fr; min-height:520px; border-bottom:var(--brd);">
  <div style="background:var(--s1); border-right:var(--brd); padding:60px 44px 52px; display:flex; flex-direction:column; justify-content:space-between;">
    <div>
      <p style="display:flex; align-items:center; gap:10px; font-size:13px; letter-spacing:0.26em; text-transform:uppercase; color:var(--muted); margin-bottom:20px;">
        <span style="display:inline-block; width:22px; height:1.5px; background:var(--terra); flex-shrink:0;"></span>
        Senior AI Fullstack Engineer · GT
      </p>
      <h1 class="hero-name" style="font-size:clamp(52px,7vw,76px); font-weight:500; text-transform:uppercase; line-height:0.94;">
        <span>Fer</span><span style="color:var(--terra);">nan</span><span style="color:var(--amber);">do</span><br>
        
        <span>Rodrí</span><span style="color:var(--terra);">guez</span>
      </h1>
      <p style="font-size:13px; color:var(--muted); line-height:1.9; margin-top:28px; max-width:340px;">
        Building production AI agents, fullstack systems, and cloud
        infrastructure. Based in Quetzaltenango, Guatemala.
      </p>
    </div>
    <div style="display:flex; flex-direction:row; gap:8px; margin-top:28px;">
      <button class="hbtn prim" style="background:var(--amber); color:var(--bg); padding:11px 24px; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; border:none;">
        Get in touch →
      </button>
      <button class="hbtn sec" style="background:transparent; border:1px solid rgba(232,224,204,0.22); color:var(--muted); padding:11px 24px; font-size:13px; letter-spacing:0.18em; text-transform:uppercase;">
        View projects
      </button>
    </div>
  </div>
  <div class="hero-art" style="position:relative; overflow:hidden; background:var(--navy);">
    <HeroArt />
    <div style="position:absolute; bottom:0; left:0; right:0; padding:10px 16px; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(232,224,204,0.3); border-top:var(--brd); background:rgba(18,17,15,0.4);">
      Identity system · 2026
    </div>
  </div>
</section>
