---
<nav style="display:flex; flex-direction:row; width:100%; background:var(--s1); border-bottom:var(--brd);">
  <div style="display:flex; flex-direction:row; align-items:center; gap:10px; padding:12px 20px; border-right:var(--brd);">
    <div style="display:grid; grid-template-columns:repeat(3,6px); grid-template-rows:repeat(3,6px); gap:1.5px;">
      <span style="display:block; width:6px; height:6px; background:var(--teal2);"></span>
      <span style="display:block; width:6px; height:6px;"></span>
      <span style="display:block; width:6px; height:6px; background:var(--cream);"></span>
      <span style="display:block; width:6px; height:6px;"></span>
      <span style="display:block; width:6px; height:6px; background:var(--amber);"></span>
      <span style="display:block; width:6px; height:6px;"></span>
      <span style="display:block; width:6px; height:6px; background:var(--cream);"></span>
      <span style="display:block; width:6px; height:6px;"></span>
      <span style="display:block; width:6px; height:6px; background:var(--teal2);"></span>
    </div>
    <span style="font-size:13px; font-weight:500; letter-spacing:0.2em; text-transform:uppercase;">F. Rodríguez</span>
  </div>
  <ul class="nav-links" style="display:flex; flex-direction:row; margin-left:auto;">
    <li style="background:var(--amber); color:var(--bg);">
      <a style="display:block; padding:12px 16px; font-size:13px; letter-spacing:0.2em; text-transform:uppercase; color:inherit;">Work</a>
    </li>
    <li style="border-left:var(--brd);">
      <a style="display:block; padding:12px 16px; font-size:13px; letter-spacing:0.2em; text-transform:uppercase; color:var(--muted);">About</a>
    </li>
    <li style="border-left:var(--brd);">
      <a style="display:block; padding:12px 16px; font-size:13px; letter-spacing:0.2em; text-transform:uppercase; color:var(--muted);">Lab</a>
    </li>
    <li style="border-left:var(--brd);">
      <a style="display:block; padding:12px 16px; font-size:13px; letter-spacing:0.2em; text-transform:uppercase; color:var(--muted);">Contact</a>
    </li>
  </ul>
</nav>
