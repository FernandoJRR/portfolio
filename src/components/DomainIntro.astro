---
import DomainArt from './DomainArt.astro'

interface Props {
  number: string
  pipColor: string
  titleFirst: string
  titleSecond: string
  domainId: string
  sectionLabel?: string
}
const { number, pipColor, titleFirst, titleSecond, domainId, sectionLabel = 'Domain' } = Astro.props
---
<div style="display:grid; grid-template-columns:260px 1fr; border-bottom:var(--brd);">
  <div style="position:relative; overflow:hidden; background:var(--navy); border-right:var(--brd); min-height:260px;">
    <DomainArt id={domainId} />
  </div>
  <div style="padding:40px 40px; background:var(--bg); display:flex; flex-direction:column; justify-content:flex-end;">
    <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
      <span style={`display:inline-block; width:8px; height:8px; background:${pipColor};`}></span>
      <span style="font-size:11px; letter-spacing:0.26em; text-transform:uppercase; color:var(--muted);">{number} — {sectionLabel}</span>
    </div>
    <div style="font-size:clamp(28px,4vw,40px); font-weight:500; text-transform:uppercase; line-height:1.1;">
      {titleFirst} <span style="opacity:0.45;">{titleSecond}</span>
    </div>
  </div>
</div>
